<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>IronCore | Registros</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-dark bg-black border-bottom border-warning mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">IRONCORE</a>
            <a href="/" class="btn btn-outline-warning btn-sm">Voltar</a>
        </div>
    </nav>

    <div class="container">
        <h2 class="text-warning mb-4">Dados Recebidos</h2>
        
        <div class="row">
            <% if (contatos.length > 0) { %>
                <% contatos.forEach(item => { %>
                    <div class="col-md-4 mb-3">
                        <div class="card bg-secondary text-white border-warning">
                            <div class="card-body">
                                <h5 class="card-title text-warning"><%= item.nomeCompleto %></h5>
                                <p class="card-text">
                                    <strong>Email:</strong> <%= item.email %><br>
                                    <strong>Assunto:</strong> <%= item.assunto || 'Não informado' %>
                                </p>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="text-muted text-center">Nenhum dado encontrado no arquivo.</p>
            <% } %>
        </div>
    </div>
</body>
</html>
