<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>TechPoint | Registros</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4 shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">TECH<span class="text-primary">POINT</span></a>
            <a href="/" class="btn btn-outline-primary btn-sm">Voltar</a>
        </div>
    </nav>

    <div class="container py-4">
        <h2 class="fw-bold mb-4">Mensagens Recebidas</h2>
        
        <div class="table-responsive shadow-sm bg-white p-3 rounded">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Assunto</th>
                        <th>Mensagem</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (contatos.length > 0) { %>
                        <% contatos.forEach(item => { %>
                            <tr>
                                <td class="fw-bold"><%= item.nomeCompleto %></td>
                                <td><%= item.email %></td>
                                <td><span class="badge bg-primary"><%= item.assunto %></span></td>
                                <td><%= item.mensagem %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="text-center text-muted">Nenhuma mensagem encontrada.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <footer class="bg-dark text-white py-4 text-center mt-5">
        <p class="mb-0">© 2026 TechPoint Admin.</p>
    </footer>
</body>
</html>
